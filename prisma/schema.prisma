generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id           String   @id @default(cuid())
  username     String   @unique 
  passwordHash String   
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
}

model FeeType {
  id             String   @id @default(cuid())
  feeCode        String   @unique 
  feeName        String   
  businessDomain String   
  quoteTypes     Json
  note           String?  
  createdBy      String   
  createdAt      DateTime @default(now())
  updatedBy      String   
  updatedAt      DateTime @updatedAt
}

model FeeTypeOperationLog {
  id            String   @id @default(cuid())
  feeTypeId     String?  
  feeCode       String   
  feeName       String   
  operationType String   
  operatorName  String   
  summary       String   
  createdAt     DateTime @default(now())
}

model UniversalImportRule {
  id           String   @id @default(cuid())
  fingerprint  String   @unique 
  ruleName     String   
  fileType     String   
  version      Int      @default(1)
  status       String   
  mapping      Json
  ruleDsl      Json?
  sampleMeta   Json?
  createdBy    String   
  updatedBy    String   
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  batches      UniversalImportBatch[]
}

model UniversalImportBatch {
  id               String                    @id @default(cuid())
  batchName        String                    
  originalFileName String                    
  sourceSheetName  String                    
  fileType         String                    
  ruleId           String?
  ruleVersion      Int?
  totalRows        Int
  successRows      Int
  failedRows       Int
  status           String                    
  parseSummary     Json?
  createdBy        String                    
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  rule             UniversalImportRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  shipments        UniversalImportShipment[]

  @@index([createdAt])
  @@index([ruleId])
}

model UniversalImportShipment {
  id              String                    @id @default(cuid())
  batchId         String
  batch           UniversalImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  externalCode    String                    
  receiverStore   String?                   
  receiverName    String?                   
  receiverPhone   String?                   
  receiverAddress String?                   
  note            String?                   
  sourceRowCount  Int
  raw             Json
  createdAt       DateTime                  @default(now())
  receiverGroups  UniversalImportShipmentReceiverGroup[]
  items           UniversalImportShipmentItem[]

  @@index([batchId])
  @@index([externalCode])
  @@index([receiverName])
}

model UniversalImportShipmentReceiverGroup {
  id              String                    @id @default(cuid())
  shipmentId      String
  shipment        UniversalImportShipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  receiverStore   String?                   
  receiverName    String?                   
  receiverPhone   String?                   
  receiverAddress String?                   
  note            String?                   
  sourceRowCount  Int
  raw             Json
  createdAt       DateTime                  @default(now())
  items           UniversalImportShipmentItem[]

  @@index([shipmentId])
  @@index([receiverName])
}

model UniversalImportShipmentItem {
  id              String                            @id @default(cuid())
  shipmentId      String
  shipment        UniversalImportShipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  receiverGroupId String?
  receiverGroup   UniversalImportShipmentReceiverGroup? @relation(fields: [receiverGroupId], references: [id], onDelete: SetNull)
  sourceRowIndex  Int
  skuCode         String                            
  skuName         String                            
  skuQuantity     Float
  skuSpec         String?                           
  raw             Json?
  createdAt       DateTime                          @default(now())

  @@index([shipmentId])
  @@index([receiverGroupId])
}
